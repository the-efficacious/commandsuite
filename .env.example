# Copy this file to .env and fill in values for local development.
# .env is gitignored; .env.example is the committed template.
#
# Loaded by `pnpm dev` via Node's --env-file-if-exists flag. Operators
# running csuite in production typically set these in their service
# manager (systemd, Docker, etc.) rather than via .env.

# ─── Server: required ──────────────────────────────────────────────

# Path to the team config file. Relative paths resolve against the
# server's CWD. Create one by copying apps/server/config.example.json
# or by running `csuite serve` interactively to trigger the first-run
# wizard.
CSUITE_CONFIG_PATH=./config.dev.json

# ─── Server: optional ──────────────────────────────────────────────

# Listen address and port. Defaults below. Binding to a non-loopback
# host auto-enables self-signed HTTPS on CSUITE_HTTPS_PORT.
CSUITE_HOST=127.0.0.1
CSUITE_PORT=8717

# Path to the SQLite database file. Defaults to ./csuite.db.
# Use :memory: for ephemeral runs (data lost on restart).
CSUITE_DB_PATH=/tmp/csuite-dev.db

# Path to the agent activity-stream database (LLM exchanges, opaque
# HTTP traces). Defaults to a sibling of CSUITE_DB_PATH.
# CSUITE_ACTIVITY_DB_PATH=/tmp/csuite-activity.db

# Key-encryption key for at-rest secrets (AES-256-GCM): TOTP secrets
# and the VAPID web-push private key. 32 raw bytes, base64-encoded.
# When unset, the server generates one at ./csuite-kek.bin on first
# boot (mode 0o600). Loss of this file + the config file together
# defeats the at-rest encryption — back both up.
# CSUITE_KEK=

# ─── CLI: client-side ──────────────────────────────────────────────

# Bearer token for `csuite` CLI commands (push, roster, objectives, ...).
# Must match a member token in the server's team config. The server
# looks up the member by hashed token and uses its name as the
# authenticated identity.
CSUITE_TOKEN=csuite_dev_replace_me

# Server URL the CLI talks to. Defaults to http://127.0.0.1:8717.
# CSUITE_URL=http://127.0.0.1:8717

# Override path for the CLI's saved auth (device-code flow output).
# Defaults to ~/.config/csuite/auth.json.
# CSUITE_AUTH_CONFIG_PATH=
