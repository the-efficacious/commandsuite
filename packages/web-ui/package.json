{
  "name": "csuite-web-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Preact team-view UI + runtime for CommandSuite — chat, objectives, files, members, tools, secrets. Host-agnostic; a host mounts it via <TeamShell>.",
  "license": "Apache-2.0",
  "author": "Andrew Jon Przybilla <andrewjon@efficacious.io>",
  "homepage": "https://github.com/the-efficacious/commandsuite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-efficacious/commandsuite.git",
    "directory": "packages/web-ui"
  },
  "bugs": {
    "url": "https://github.com/the-efficacious/commandsuite/issues"
  },
  "keywords": [
    "csuite",
    "web-ui",
    "ui",
    "preact",
    "embeddable"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/index.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "csuite-sdk": "workspace:*",
    "@preact/signals": "^2.9.4",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "lucide-preact": "^1.25.0",
    "marked": "^18.0.6",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.6",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.9.0",
    "happy-dom": "^20.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
