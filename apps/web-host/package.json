{
  "name": "csuite-web-host",
  "version": "0.0.1",
  "description": "OSS web host for CommandSuite — TOTP auth gate + PWA that mounts the shared csuite-web-ui <TeamShell>, served by the self-hosted broker.",
  "license": "Apache-2.0",
  "author": "Andrew Jon Przybilla <andrewjon@efficacious.io>",
  "homepage": "https://github.com/the-efficacious/commandsuite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-efficacious/commandsuite.git",
    "directory": "apps/web-host"
  },
  "bugs": {
    "url": "https://github.com/the-efficacious/commandsuite/issues"
  },
  "keywords": [
    "csuite",
    "web-host",
    "spa",
    "pwa",
    "preact"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./dist/index.html": "./dist/index.html",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "csuite-sdk": "workspace:*",
    "csuite-web-ui": "workspace:*",
    "@preact/signals": "^2.9.4",
    "preact": "^10.29.7",
    "workbox-precaching": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.6",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^26.1.1",
    "@unocss/preset-wind4": "^66.7.5",
    "@unocss/reset": "^66.7.5",
    "happy-dom": "^20.11.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
