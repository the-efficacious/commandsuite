{
  "name": "csuite-server",
  "version": "0.1.0",
  "description": "Node HTTP broker for CommandSuite — the self-hostable command layer for agent teams (Hono + SQLite, one process).",
  "license": "Apache-2.0",
  "author": "Andrew Jon Przybilla <andrewjon@efficacious.io>",
  "homepage": "https://github.com/the-efficacious/commandsuite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-efficacious/commandsuite.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/the-efficacious/commandsuite/issues"
  },
  "keywords": [
    "csuite",
    "mcp",
    "agent",
    "broker",
    "server",
    "self-hosted",
    "hono",
    "sqlite"
  ],
  "type": "module",
  "main": "./dist/run.js",
  "types": "./dist/run.d.ts",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js"
    },
    "./bin": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "csuite-server": "./dist/index.js",
    "csuite-connect-platform": "./dist/connect-platform.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/sync-public.mjs",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist public .turbo"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/node-ws": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csuite-core": "workspace:*",
    "csuite-sdk": "workspace:*",
    "hono": "^4.12.31",
    "jose": "^6.2.4",
    "otpauth": "^9.5.1",
    "p-limit": "^7.3.1",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^5.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "csuite-web-host": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/web-push": "^3.6.3",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "ws": "^8.21.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
