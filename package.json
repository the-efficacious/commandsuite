{
  "name": "commandsuite",
  "version": "0.0.0",
  "private": true,
  "description": "Control plane for AI agent operations. OSS monorepo.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=csuite-server --filter=csuite-web-host",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/aggregate-changelog.mjs",
    "verify-pack": "node scripts/verify-pack-contents.mjs",
    "release": "changeset publish",
    "wizard": "node packages/cli/dist/index.js setup",
    "csuite": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.9.14",
    "typescript": "^7.0.2",
    "vite": "^8.0.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
